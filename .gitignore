# Generated knowledge-graph output — regenerable via `graphify extract`.
# The CLI itself treats graphify-out/ as a cache (its `uninstall --purge`
# flag deletes it). Keep it local; do not commit the 6.8MB of prebuilt
# graph chunks / HTML render / etc.
graphify-out/

# Scratch / probe / one-off artifacts (leading-underscore convention).
# Match by extension so legitimate test fixtures or files like
# `_dump.test.ts` aren't swept up. The leading-underscore convention
# is enforced by code review, not by accidentally broad globs.
_*.cjs
_*.js
_*.mjs
_*.ts
_*.sh
_*.py
_*.json
_*.md
_*.html
_*.txt

# Generated test artifacts (snapshots, fixtures, output — not source test files)
test-bed/
test-snapshots/
snapshots/
*.snap

# Understand Anything (analysis artifacts)
.understand-anything/
!.understand-anything/.understandignore
*.bak.*
*fuzz*
SANDBOX_SECURITY_ROADMAP.md
skills/writing-skills/examples/CLAUDE_MD_TESTING.md

# Internal security docs — keep local, never publish (see SANDBOX_SECURITY_ROADMAP.md precedent)
security-review.md
docs/audit-fix-spec.md
