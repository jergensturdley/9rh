{
  "name": "9rh",
  "version": "1.0.0",
  "description": "Local coding-agent harness with pluggable LLM backends (9router, OpenAI, OpenRouter, Ollama, LM Studio)",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "exports": {
    ".": "./dist/main.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "9rh": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "postinstall": "node scripts/postinstall.cjs",
    "test": "NODE_OPTIONS='--experimental-vm-modules' node_modules/jest/bin/jest.js --config jest.config.ts"
  },
  "keywords": [
    "coding-agent",
    "agent",
    "llm",
    "openai",
    "openrouter",
    "ollama",
    "lmstudio",
    "9router",
    "codegraph",
    "sandbox",
    "repl"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.19",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module"
}
