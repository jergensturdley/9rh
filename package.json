{
  "name": "9rh",
  "version": "1.0.0",
  "description": "Coding agent harness for 9router",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "exports": {
    ".": "./dist/main.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "9rh": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "postinstall": "node dist/index.js init --quiet",
    "test": "NODE_OPTIONS='--experimental-vm-modules' node_modules/jest/bin/jest.js --config jest.config.ts"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "express": "^5.2.1",
    "openai": "^4.77.0",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module"
}
